<configuration>

    <appender name="consoleLog" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{HH:mm:ss.SSS} %p [%t] %C{0}:%line: %m [traceId: %X{traceId:-} spanId: %X{spanId:-}] %n
                </pattern>
            </encoder>
    </appender>

    <logger name="org.apache.kafka.clients.admin.*" level="OFF"/>
    <logger name="Environment" level="OFF"/>
    <logger name="AbstractConfig" level="OFF"/>

    <root>
        <level value="INFO"/>
        <appender-ref ref="consoleLog"/>
    </root>

</configuration>
